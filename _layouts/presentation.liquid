---
layout: page
---
<div class="presentation">
  <div
    class="talk-metadata"
    style="margin-bottom: 20px; padding: 15px; background: var(--global-bg-color); border-left: 5px solid var(--global-theme-color); border-radius: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);"
  >
    <p style="margin-bottom: 5px;"><strong>Event:</strong> {{ page.event }}</p>
    <p style="margin-bottom: 5px;"><strong>Date:</strong> {{ page.date | date: '%B %d, %Y' }}</p>
    {% if page.location %}
      <p style="margin-bottom: 5px;"><strong>Location:</strong> {{ page.location }}</p>
    {% endif %}

    <div class="talk-links" style="margin-top: 15px;">
      {% if page.slides %}
        <a href="{{ page.slides | relative_url }}" class="btn btn-sm z-depth-0" role="button" style="border: 1px solid var(--global-theme-color);">
          <i class="fa-solid fa-file-pdf"></i> Slides (PDF)
        </a>
      {% endif %}
      {% if page.video %}
        <a href="{{ page.video }}" class="btn btn-sm z-depth-0" role="button" target="_blank" style="border: 1px solid var(--global-theme-color);">
          <i class="fa-solid fa-video"></i> Video
        </a>
      {% endif %}
    </div>
  </div>

  {{ content }}
</div>
